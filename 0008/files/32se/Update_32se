Version exec.library version 47 >NIL:
If Warn
   echo"Minimum Kickstart 3.2 & AmigaOS 3.2x is needed"
   endcli
endif
FailAt 31
CPU CHECKINSTALL

if not exists c:loadmodule
    echo " "
    echo "You need to install Modules first!! (from AmigaOS3.2 CD ADF Drawer)"
    endcli
endif

echo " " 
echo " "

echo " Welcome to 32se installer"
echo " "
echo " This updates 32se to v8.85"
echo " "
echo " "

ask " Press Enter to continue !"

if not exists libs:68040.library
   	echo " "
   	echo "You need to install CPU Support Libraries first!! (from AmigaOS3.2 CD Installer)"
   	ask " " 
   	endcli
endif

wait 1
lha x -m 32se_update.lha sys:
wait 1
T:reboot
